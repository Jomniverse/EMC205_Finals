  m_Script: {fileID: 11500000, guid: 08295ed304ff2404a9b21629facf9a20, type: 3}
  m_Name: Mail_1
  m_EditorClassIdentifier: 
  sender: Human Resources
  subject: Welcome to the IERF Family
  message: "Welcome to I.E.R.F. or the [INTERNATIONAL ENTITY RESISTANCE FORCE]. Here
    at I.E.R.F, we put our clients first. That means you, our latest addition to
    the family, must do your best to deliver accurate information and help our clients
    with their entity issues. You must submit the right information to your clients
    based on their observations. You'd better do your best, we wouldn't want anyone
    dying on us now, would we? Also, keep in mind that, as per usual, your accuracy
    rate will determine your wage for the day, so do your best.\r\nThank you for
    your service. See you soon.\r\n\nSincerely,\r\nI.E.R.F. Human Resources\r"
